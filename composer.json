{
    "name": "orionphp/open-meteo",
    "description": "Typed PHP 8.4 client for the Open-Meteo API",
    "authors": [
        {
            "name": "Dennis Leisdorff",
            "email": "dle79@proton.me"
        }
    ],
    "type": "library",
    "license": "MIT",

    "keywords": [
        "open-meteo",
        "openmeteo",
        "weather",
        "forecast",
        "weather-api",
        "weather-forecast",
        "weather-data",
        "weather-model",
        "weathercode",
        "meteorology",
        "php-api-client",
        "free api",
        "free weather api",
        "api-client",
        "php",
        "psr-18"
    ],

    "config": {
        "sort-packages": true
    },

    "require": {
        "php": "^8.4",
        "psr/log": "^3.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.1"
    },

    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "guzzlehttp/guzzle": "^7.1",
        "nyholm/psr7": "^1.7",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0",
        "symfony/var-dumper": "^8.0"
    },

    "suggest": {
        "guzzlehttp/guzzle": "PSR-18 HTTP client implementation",
        "symfony/http-client": "Alternative PSR-18 HTTP client",
        "nyholm/psr7": "PSR-7 / PSR-17 implementation"
    },

    "scripts": {
        "cs": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "stan": "phpstan analyse",
        "test": "phpunit",
        "check": [
            "@cs-check",
            "@stan",
            "@test"
        ]
    },

    "autoload": {
        "psr-4": {
            "Orionphp\\OpenMeteo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Orionphp\\OpenMeteo\\Tests\\": "tests/"
        }
    }
}
