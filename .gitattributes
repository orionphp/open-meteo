###############################################################################
# Normalize line endings
###############################################################################

* text=auto

# Force LF for source code and configs
*.php text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.neon text eol=lf
*.dist text eol=lf

# Windows scripts
*.bat text eol=crlf


###############################################################################
# Better Git diffs
###############################################################################

*.php diff=php

###############################################################################
# Ignore dev files in Composer / GitHub archives
###############################################################################

/tests export-ignore
/.github export-ignore
/.gitignore export-ignore
/.gitattributes export-ignore

/phpunit.xml export-ignore
/phpunit.xml.dist export-ignore
/phpstan.neon export-ignore
/phpstan.neon.dist export-ignore
/.php-cs-fixer.php export-ignore

###############################################################################
# Linguist (GitHub language stats)
###############################################################################

/tests linguist-vendored